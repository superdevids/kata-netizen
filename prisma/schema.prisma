// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Isu {
  id         String   @id @default(uuid())
  slug       String?  @unique
  judul      String
  deskripsi  String   @db.Text
  konten     String   @db.Text
  thumbnail  String   @db.Text
  kategori   String
  kata_kunci String   @db.Text
  aktif      Boolean  @default(true)
  is_draft   Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  // Relations
  postingan          Postingan[]
  tren_harian        TrenHarian[]
  reaksi_platform    ReaksiPlatform[]
  eskalasi           Eskalasi[]
  momentum_shift     MomentumShift[]
  echo_chamber       EchoChamber[]
  isu_a              PerbandinganIsu[]   @relation("IsuA")
  isu_b              PerbandinganIsu[]   @relation("IsuB")
  indeks_kepercayaan IndeksKepercayaan[]
  narasi             Narasi[]
  entitas_agregat    EntitasAgregat[]
  keyword_harian     KeywordHarian[]
  summary_isu        SummaryIsu[]

  @@map("isu")
}

model Postingan {
  id           String    @id @default(uuid())
  isu_id       String
  platform     String
  judul        String?   @db.Text
  url          String?   @db.Text
  tanggal_post DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now()) @updatedAt

  isu      Isu        @relation(fields: [isu_id], references: [id], onDelete: Cascade)
  komentar Komentar[]

  @@map("postingan")
}

model Komentar {
  id           String    @id @default(uuid())
  postingan_id String
  username     String?
  teks         String    @db.Text
  tanggal      DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now()) @updatedAt

  postingan Postingan @relation(fields: [postingan_id], references: [id], onDelete: Cascade)
  analisis  Analisis?
  entitas   Entitas[]

  @@index([tanggal])
  @@index([postingan_id])
  @@map("komentar")
}

model Analisis {
  id              String   @id @default(uuid())
  komentar_id     String   @unique
  sentimen        String?
  emosi           String?
  stance          String?
  intensitas      String?
  is_sarkasme     Boolean  @default(false)
  is_toxic        Boolean  @default(false)
  conf_sentimen   Decimal? @db.Decimal(5, 4)
  conf_emosi      Decimal? @db.Decimal(5, 4)
  conf_stance     Decimal? @db.Decimal(5, 4)
  conf_intensitas Decimal? @db.Decimal(5, 4)
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt
  komentar        Komentar @relation(fields: [komentar_id], references: [id], onDelete: Cascade)

  @@index([sentimen])
  @@index([emosi])
  @@index([stance])
  @@map("analisis")
}

model Entitas {
  id          String   @id @default(uuid())
  komentar_id String
  tipe        String?
  nilai       String   @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  komentar Komentar @relation(fields: [komentar_id], references: [id], onDelete: Cascade)

  @@index([tipe])
  @@map("entitas")
}

model TrenHarian {
  id             String   @id @default(uuid())
  isu_id         String
  platform       String
  tanggal        DateTime @db.Date
  total_komentar Int      @default(0)
  jml_positif    Int      @default(0)
  jml_negatif    Int      @default(0)
  jml_netral     Int      @default(0)
  pct_positif    Decimal? @db.Decimal(5, 2)
  pct_negatif    Decimal? @db.Decimal(5, 2)
  pct_netral     Decimal? @db.Decimal(5, 2)
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt

  isu Isu @relation(fields: [isu_id], references: [id], onDelete: Cascade)

  @@unique([isu_id, platform, tanggal])
  @@index([tanggal])
  @@map("tren_harian")
}

model ReaksiPlatform {
  id                String   @id @default(uuid())
  isu_id            String
  platform          String
  tanggal           DateTime @db.Date
  total_komentar    Int      @default(0)
  pct_positif       Decimal? @db.Decimal(5, 2)
  pct_negatif       Decimal? @db.Decimal(5, 2)
  pct_netral        Decimal? @db.Decimal(5, 2)
  pct_mendukung     Decimal? @db.Decimal(5, 2)
  pct_menolak       Decimal? @db.Decimal(5, 2)
  pct_netral_stance Decimal? @db.Decimal(5, 2)
  dominant_emosi    String?
  toxic_rate        Decimal? @db.Decimal(5, 2)
  sarkasme_rate     Decimal? @db.Decimal(5, 2)
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now()) @updatedAt

  isu Isu @relation(fields: [isu_id], references: [id], onDelete: Cascade)

  @@unique([isu_id, platform, tanggal])
  @@map("reaksi_platform")
}

model Eskalasi {
  id            String   @id @default(uuid())
  isu_id        String
  platform      String?
  tanggal       DateTime @db.Date
  delta_negatif Int?
  delta_pct     Decimal? @db.Decimal(5, 2)
  level         String?
  is_eskalasi   Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  isu Isu @relation(fields: [isu_id], references: [id], onDelete: Cascade)

  @@index([tanggal])
  @@map("eskalasi")
}

model MomentumShift {
  id               String   @id @default(uuid())
  isu_id           String
  tanggal          DateTime @db.Date
  sentimen_sebelum String?
  sentimen_sesudah String?
  magnitude        Decimal? @db.Decimal(5, 4)
  keterangan       String?  @db.Text
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now()) @updatedAt

  isu Isu @relation(fields: [isu_id], references: [id], onDelete: Cascade)

  @@map("momentum_shift")
}

model EchoChamber {
  id                String   @id @default(uuid())
  isu_id            String
  platform          String?
  tanggal           DateTime @db.Date
  variance_sentimen Decimal? @db.Decimal(8, 6)
  variance_stance   Decimal? @db.Decimal(8, 6)
  is_echo_chamber   Boolean  @default(false)
  keterangan        String?  @db.Text
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now()) @updatedAt

  isu Isu @relation(fields: [isu_id], references: [id], onDelete: Cascade)

  @@map("echo_chamber")
}

model PerbandinganIsu {
  id                String   @id @default(uuid())
  isu_a_id          String
  isu_b_id          String
  tanggal           DateTime @db.Date
  korelasi_sentimen Decimal? @db.Decimal(5, 4)
  korelasi_stance   Decimal? @db.Decimal(5, 4)
  keterangan        String?  @db.Text
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now()) @updatedAt

  isu_a Isu @relation("IsuA", fields: [isu_a_id], references: [id], onDelete: Cascade)
  isu_b Isu @relation("IsuB", fields: [isu_b_id], references: [id], onDelete: Cascade)

  @@map("perbandingan_isu")
}

model IndeksKepercayaan {
  id            String   @id @default(uuid())
  isu_id        String
  tanggal       DateTime @db.Date
  skor_sentimen Decimal? @db.Decimal(5, 2)
  skor_stance   Decimal? @db.Decimal(5, 2)
  skor_eskalasi Decimal? @db.Decimal(5, 2)
  indeks_final  Decimal? @db.Decimal(5, 2)
  kategori      String?
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  isu Isu @relation(fields: [isu_id], references: [id], onDelete: Cascade)

  @@unique([isu_id, tanggal])
  @@map("indeks_kepercayaan")
}

model Narasi {
  id              String   @id @default(uuid())
  isu_id          String
  tanggal         DateTime @db.Date
  narasi_ke       Int?
  kata_kunci      Json?
  jumlah_komentar Int?
  persentase      Decimal? @db.Decimal(5, 2)
  contoh_komentar Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  isu Isu @relation(fields: [isu_id], references: [id], onDelete: Cascade)

  @@index([tanggal])
  @@map("narasi")
}

model EntitasAgregat {
  id         String   @id @default(uuid())
  isu_id     String
  tanggal    DateTime @db.Date
  tipe       String?
  nilai      String   @db.Text
  jumlah     Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  isu Isu @relation(fields: [isu_id], references: [id], onDelete: Cascade)

  @@index([tanggal])
  @@index([tipe])
  @@map("entitas_agregat")
}

model KeywordHarian {
  id         String   @id @default(uuid())
  isu_id     String
  tanggal    DateTime @db.Date
  sentimen   String?
  kata       String
  frekuensi  Int      @default(0)
  skor_tfidf Decimal? @db.Decimal(8, 6)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  isu Isu @relation(fields: [isu_id], references: [id], onDelete: Cascade)

  @@index([tanggal])
  @@index([sentimen])
  @@map("keyword_harian")
}

model SummaryIsu {
  id         String   @id @default(uuid())
  isu_id     String
  tanggal    DateTime @db.Date
  periode    String?
  judul      String?  @db.Text
  konten     String?  @db.LongText
  editor     String?
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  isu Isu @relation(fields: [isu_id], references: [id], onDelete: Cascade)

  @@index([tanggal])
  @@map("summary_isu")
}

model VisitorLog {
  id          String   @id @default(uuid())
  visitor_id  String?
  session_id  String?
  page_url    String?  @db.Text
  referrer    String?  @db.Text
  device_type String?
  browser     String?
  os          String?
  country     String?
  city        String?
  ip_address  String?
  visited_at  DateTime @default(now())

  @@index([visited_at])
  @@map("visitor_logs")
}

model Subscriber {
  id              String    @id @default(uuid())
  email           String    @unique
  is_active       Boolean   @default(true)
  subscribed_at   DateTime  @default(now())
  unsubscribed_at DateTime?

  @@index([email])
  @@index([is_active])
  @@map("subscribers")
}
